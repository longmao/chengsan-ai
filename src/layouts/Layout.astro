---
interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title,
  description = '杨总 · AI Native 个人站',
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const siteUrl = 'https://longmao.github.io';
const fullUrl = `${siteUrl}/chengsan-ai${canonicalPath.startsWith('/') ? canonicalPath : '/' + canonicalPath}`;
const ogImage = `${siteUrl}/chengsan-ai/favicon.svg`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={fullUrl} />
    <link rel="icon" type="image/svg+xml" href="/chengsan-ai/favicon.svg" />

    <!-- Open Graph · 国内微信 / LinkedIn / Twitter 分享卡片依赖 -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} · chengsan-ai`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="chengsan-ai" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} · chengsan-ai`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="alternate" type="application/rss+xml" title="chengsan-ai" href="/chengsan-ai/rss.xml" />

    <title>{title} · chengsan-ai</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/chengsan-ai/" class="brand">chengsan.ai</a>
      <nav class="site-nav">
        <a href="/chengsan-ai/">首页</a>
        <a href="/chengsan-ai/notes">笔记</a>
      </nav>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>© 杨总 · AI Native · <a href="https://github.com/longmao/chengsan-ai">源码</a></p>
    </footer>
  </body>
</html>

<style>
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--color-border, #e5e5e5);
  }
  .brand { font-weight: 600; letter-spacing: -0.01em; text-decoration: none; color: inherit; }
  .site-nav a { margin-left: 1.5rem; text-decoration: none; color: var(--color-text-muted, #666); }
  .site-main { max-width: 720px; box-sizing: border-box; margin: 0 auto; padding: 4rem 2rem; }
  .site-footer { padding: 4rem 2rem; border-top: 1px solid var(--color-border, #e5e5e5); text-align: center; color: var(--color-text-muted, #999); font-size: 0.875rem; }
  .site-footer a { color: inherit; }
</style>
