---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection('notes');
const landings = await getCollection('landings');
notes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
landings.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Index" description="杨总 · AI Native 个人站 · 编辑型 IP 索引与作品集">
  <div class="site-shell">

    <header class="site-header">
      <a href="/chengsan-ai/" class="brand">chengsan.ai</a>
      <nav class="site-nav">
        <a href="/chengsan-ai/" aria-current="page">Index</a>
        <a href="/chengsan-ai/notes/">Notes</a>
        <a href="/chengsan-ai/landings/">Landings</a>
      </nav>
    </header>

    <main class="site-main">

      <!-- HERO: editorial calm · §4.7 max 4 text elements (kicker + headline + subtext + cta) -->
      <section class="hero">
        <span class="kicker-accent">AI Native · Engineering Practice · 2026</span>
        <h1>杨总的主张、笔记、和做事。</h1>
        <p class="lead">
          5x8 在场，agent 7x24xn 并行。<br />
          下面是我在工地上的真实产物，结构化编辑，方便以后翻。
        </p>
        <p class="cta-row">
          <a class="btn btn-primary" href="/chengsan-ai/notes/">看最新笔记</a>
          <a class="btn btn-secondary" href="/chengsan-ai/landings/">看项目作品</a>
        </p>
      </section>

      <!-- ABOUT: simple editorial block (calm chrome) -->
      <section class="section calm about">
        <span class="kicker-accent">about</span>
        <p>个人 AI Native OS 着陆点 · 西安装 / 国内主战场 · 内容 / 工程 / 投资协作。<br />
        主张：「职场除了利弊还有对错」 · 战术：dual-layer calm chrome + carrier 系统。<br />
        工具：Claude Code · harness discipline · launchd + hermes · 7x24 loop。</p>
      </section>

      <!-- LANDINGS (carrier: 项目库) -->
      {landings.length > 0 && (
        <section class="section calm-2">
          <span class="eyebrow">Projects</span>
          <h2>做的项目</h2>
          <div class="calm-list">
            {landings.map(item => (
              <div class="item">
                <div>
                  <a href={`/chengsan-ai/landings/${item.slug}`} class="project-title">
                    {item.data.title}
                  </a>
                  <p>{item.data.description}</p>
                </div>
                <span class="meta">
                  {item.data.pubDate.toISOString().slice(0, 10)}
                  {' '}
                  <span class="dim">/</span>
                  {' '}
                  <span class="tag">landing</span>
                </span>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- NOTES (carrier: 笔记集) -->
      {notes.length > 0 && (
        <section class="section calm">
          <span class="eyebrow">Notes</span>
          <h2>在写的笔记</h2>
          <div class="calm-list">
            {notes.map(note => (
              <div class="item">
                <div>
                  <a href={`/chengsan-ai/notes/${note.slug}`} class="project-title">
                    {note.data.title}
                  </a>
                  <p>{note.data.description}</p>
                </div>
                <span class="meta">
                  {note.data.pubDate.toISOString().slice(0, 10)}
                </span>
              </div>
            ))}
          </div>
        </section>
      )}

      <hr class="calm-divider" />

      <!-- CONTACT: minimal single carrier (a small quiet block) -->
      <section class="section calm contact">
        <span class="eyebrow">contact</span>
        <p>
          微信 <code>diwucun</code>
          <span class="dim"> / </span>
          email <code>longmao(at)chengsan.ai</code>
          <span class="dim"> / </span>
          X / GitHub <a href="https://github.com/longmao">@longmao</a>
        </p>
        <p class="meta">本站 chengsan-ai · 长秒算 · 开源于 <a href="https://github.com/longmao/chengsan-ai">GitHub</a> · 内容仅代表个人立场</p>
      </section>

    </main>

    <footer class="site-footer">
      <p>chengsan.ai · 杨总 · AI Native</p>
      <p class="kicker">
        <a href="https://github.com/longmao/chengsan-ai">source</a>
        <span class="dim">/</span>
        <a href="/chengsan-ai/rss.xml">rss</a>
        <span class="dim">/</span>
        <a href="https://github.com/longmao/chengsan-ai/blob/main/docs/REDESIGN_SPEC.md">spec</a>
      </p>
    </footer>

  </div>
</Layout>

<style>
  /* Hero - editorial calm + single carrier kicker (no glass) */
  .hero {
    padding: var(--space-xl) 0 var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }
  .hero .lead {
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 400;
    line-height: 1.45;
    color: var(--color-text-muted);
    max-width: 32rem;
    margin: 0 0 var(--space-md);
  }
  .hero .cta-row {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  /* About - calm surface, plain text */
  .about p {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text);
    max-width: 38rem;
  }

  /* Calm list item */
  .item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem var(--space-md);
    align-items: baseline;
  }
  .project-title {
    font-weight: 600;
    font-size: 1.125rem;
    text-decoration: none;
    color: var(--color-text);
  }
  .project-title:hover {
    color: var(--color-accent);
  }
  .item p {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    margin: 0.25rem 0 0;
    max-width: 36rem;
  }
  .item .meta {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-subtle);
    margin: 0;
    white-space: nowrap;
  }
  .item .dim {
    color: var(--color-text-subtle);
    margin: 0 0.25rem;
  }
  .item .tag {
    color: var(--color-text-muted);
  }

  /* Divider */
  .calm-divider {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }

  /* Contact - code style calm */
  .contact p code {
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    padding: 0.15em 0.5em;
    border-radius: 3px;
    font-size: 0.875em;
  }

  /* Mobile responsive for hero stack */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-lg) 0 var(--space-xl);
    }
    .item {
      grid-template-columns: 1fr;
    }
    .item .meta {
      margin-top: 0.5rem;
    }
  }
</style>
