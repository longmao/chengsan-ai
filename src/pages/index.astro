---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection('notes');
notes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="首页" description="杨总个人 AI Native 站 · AI native 工程实践 / 投资 / 7x24 调研 / 笔记">
  <section class="hero">
    <h1>chengsan.ai</h1>
    <p class="lead">
      AI Native OS 个人的内容着陆点。<br />
      工程实践、投资协作、7x24 调研——能对外讲的，都放这。
    </p>
  </section>

  <section class="notes-index">
    <h2>笔记</h2>
    <ul class="note-list">
      {notes.map(note => (
        <li>
          <a href={`/chengsan-ai/notes/${note.slug}`}>
            <span class="note-title">{note.data.title}</span>
            <span class="note-desc">{note.data.description}</span>
          </a>
          <span class="note-date">{note.data.pubDate.toISOString().slice(0, 10)}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="contact">
    <h2>关于</h2>
    <p>
      杨总 · <a href="https://github.com/longmao">@longmao</a> ·
      西安 · 5x8 在场 · agent 7x24xn 并行。
    </p>
  </section>
</Layout>

<style>
  .hero { margin-bottom: 4rem; }
  .lead { font-family: var(--font-serif); font-size: 1.25rem; color: var(--color-text-muted); line-height: 1.5; max-width: 32rem; }

  .notes-index { margin-bottom: 4rem; }
  .note-list { list-style: none; padding: 0; }
  .note-list li {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem 2rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
    align-items: baseline;
    max-width: none;
  }
  .note-list a { display: contents; text-decoration: none; color: inherit; }
  .note-title { font-weight: 500; }
  .note-desc { grid-column: 1; color: var(--color-text-muted); font-size: 0.95rem; }
  .note-date { color: var(--color-text-subtle); font-size: 0.85rem; font-variant-numeric: tabular-nums; }

  .contact { border-top: 1px solid var(--color-border); padding-top: 2rem; }
</style>
