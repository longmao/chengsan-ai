---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const landings = await getCollection('landings');
landings.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Landings" description="chengsan.ai / landings · 杨总做的项目索引">
  <div class="site-shell">

    <header class="site-header">
      <a href="/chengsan-ai/" class="brand">chengsan.ai</a>
      <nav class="site-nav">
        <a href="/chengsan-ai/">Index</a>
        <a href="/chengsan-ai/notes/">Notes</a>
        <a href="/chengsan-ai/landings/" aria-current="page">Landings</a>
      </nav>
    </header>

    <main class="site-main">

      <section class="page-head">
        <span class="kicker-accent">projects</span>
        <h1>项目</h1>
        <p>做的、能看的、能用的。每个项目都有一份完整说明。</p>
      </section>

      {landings.length === 0 ? (
        <p class="meta">暂无项目。</p>
      ) : (
        <section class="section calm">
          <div class="calm-list">
            {landings.map(item => (
              <div class="item">
                <div>
                  <a href={`/chengsan-ai/landings/${item.slug}`} class="project-title">{item.data.title}</a>
                  <p>{item.data.description}</p>
                </div>
                <span class="meta">
                  {item.data.pubDate.toISOString().slice(0, 10)}
                </span>
              </div>
            ))}
          </div>
        </section>
      )}

    </main>

    <footer class="site-footer">
      <p>chengsan.ai · 杨总 · AI Native</p>
      <p class="kicker"><a href="/chengsan-ai/">回到 index</a></p>
    </footer>

  </div>
</Layout>

<style>
  .page-head {
    padding: var(--space-xl) 0 var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-xl);
  }
  .page-head p {
    font-family: var(--font-serif);
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin: 0;
  }
  .calm-list .item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem var(--space-md);
    align-items: baseline;
  }
  .project-title {
    font-weight: 600;
    font-size: 1.125rem;
    text-decoration: none;
    color: var(--color-text);
  }
  .project-title:hover {
    color: var(--color-accent);
  }
  .item p {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    margin: 0.25rem 0 0;
  }
  .item .meta {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-subtle);
    white-space: nowrap;
  }
  @media (max-width: 768px) {
    .item { grid-template-columns: 1fr; }
    .item .meta { margin-top: 0.5rem; }
  }
</style>
